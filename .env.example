# CloseCRM — Supabase configuration
# 1. Create a free project at https://supabase.com
# 2. Go to Project Settings → API
# 3. Copy the Project URL and anon public API key below.
# 4. Copy this file to ".env" and fill in the values, then restart `npm run dev`.

VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Base URL of the SaleMail backend API (server/server.js).
# Defaults to http://localhost:3001 for local dev if unset.
VITE_API_URL="http://localhost:3001"
