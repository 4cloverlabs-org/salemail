PORT=3001

# Google OAuth (Google Cloud Console -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Comma-separated list of browser origins allowed to call this API (CORS).
ALLOWED_ORIGINS=http://localhost:5173

# Supabase Configuration (Matches Frontend .env)
VITE_SUPABASE_URL=""

# Supabase Service Role Key (Found in Supabase Dashboard -> Project Settings -> API)
# WARNING: NEVER put this in the frontend .env! Only for the server.
SUPABASE_SERVICE_ROLE_KEY=""

# Groq API key (server-side only; never expose to the browser)
GROQ_API_KEY=""
